# Copy to values.secret.yaml (gitignored) and fill in your Telegram chat ID.
# Get your chat ID by messaging the bot, then checking:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
#
# The bot token itself is NOT set here - it's mounted from the
# telegram-bot-token secret (see values.yaml and the README).

alertmanager:
  config:
    receivers:
      - name: telegram
        telegram_configs:
          - bot_token_file: /etc/alertmanager/secrets/telegram-bot-token/token
            chat_id: 123456789
            message: |
              {{ range .Alerts }}
              [{{ .Labels.severity | toUpper }}] {{ .Labels.alertname }}
              {{ .Annotations.summary }}
              {{ end }}
